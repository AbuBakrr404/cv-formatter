# Copy this file to .env and fill in your values for local development.
# On Railway, set these as environment variables in the Variables tab instead.

# Your Anthropic API key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Password the team enters to access the deployed app.
# Choose something memorable but not easily guessable.
# If left blank/unset, the password gate is disabled (useful for local dev only).
APP_PASSWORD=ChooseAStrongPassword
